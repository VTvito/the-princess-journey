# --- Dev tooling (the game itself has no build step; these are test-harness only) ---
node_modules/
npm-debug.log*
yarn-error.log*

# Playwright browser cache / traces (we launch installed Edge, not a download)
.playwright/
playwright-report/
test-results/
*.webm
# Smoke-test screenshot output (regenerated every run)
tools/test/*.png

# --- Python tooling cruft ---
__pycache__/
*.py[cod]

# --- Secrets (LOCAL ONLY — never commit) ---
# Holds VERCEL_TOKEN for `npm run deploy`. See README "Deploy".
.env
.env.*

# --- Personal / local config (machine-specific; not shared) ---
.claude/settings.local.json

# --- Editors ---
.vscode/
.idea/
*.swp

# --- OS cruft ---
Thumbs.db
Desktop.ini
.DS_Store

.vercel
